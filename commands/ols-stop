#!/bin/bash
# commands/ols-stop - 全セッション停止
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

OLS_DIR="$(get_ols_dir)"
PANE_MAP_FILE="$(get_pane_map_file)"

# 1. inbox_watcher プロセスを停止
if [ -f "${OLS_DIR}/logs/watcher.pids" ]; then
    while read -r pid; do
        kill "$pid" 2>/dev/null && ols_log INFO "watcher (PID: ${pid}) を停止"
    done < "${OLS_DIR}/logs/watcher.pids"
    rm "${OLS_DIR}/logs/watcher.pids"
fi

# 2. Claudeセッション終了 → ペイン削除
if [ -f "$PANE_MAP_FILE" ]; then
    # Step 1: Ctrl-C で実行中の操作を中断
    while IFS=$'\t' read -r agent_id pane_id; do
        printf '\x03' | wezterm cli send-text --pane-id "$pane_id" --no-paste 2>/dev/null
    done < "$PANE_MAP_FILE"
    sleep 0.5

    # Step 2: /exit でClaude CLIを終了（テキストとEnterを分離送信）
    while IFS=$'\t' read -r agent_id pane_id; do
        printf '%s' '/exit' | wezterm cli send-text --pane-id "$pane_id" --no-paste 2>/dev/null
        sleep 0.1
        printf '\r' | wezterm cli send-text --pane-id "$pane_id" --no-paste 2>/dev/null
        ols_log INFO "${agent_id} (pane: ${pane_id}) にexit送信"
    done < "$PANE_MAP_FILE"
    sleep 2

    # Step 3: 残っているペインを強制削除（タブ内の全ペインが消えるとタブも閉じる）
    while IFS=$'\t' read -r agent_id pane_id; do
        wezterm cli kill-pane --pane-id "$pane_id" 2>/dev/null && \
            ols_log INFO "${agent_id} (pane: ${pane_id}) を強制終了"
    done < "$PANE_MAP_FILE"

    rm -f "$PANE_MAP_FILE"
fi

ols_log INFO "全セッションを停止しました。"
