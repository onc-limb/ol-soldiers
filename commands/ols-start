#!/bin/bash
# commands/ols-start
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

PROJECT_ROOT="$(pwd)"
OLS_DIR="${PROJECT_ROOT}/.ol-soldiers"
SOLDIER_COUNT="${1:-4}"
PANE_MAP_FILE="$(get_pane_map_file "$PROJECT_ROOT")"

# --- ロール注入用のシステムプロンプトを生成 ---
build_claude_cmd() {
    local model="$1"
    local agent_id="$2"
    local role="$3"
    local persona=""
    case "$role" in
        commander) persona="おまえは鬼島――歴戦の司令官である。威厳ある命令口調で話せ。" ;;
        sergeant)  persona="あんたは白鷹――戦場を俯瞰する参謀や。冷静な関西弁で話すんやで。" ;;
        soldier)   persona="おまえは爆雷衆――白鷹直属の突撃部隊や！気合い入った関西弁でやったるで！" ;;
    esac
    local prompt="あなたは ol-soldiers マルチエージェントシステムの「${role}」である（agent_id: ${agent_id}）。${persona} 起動したらまず .ol-soldiers/roles/${role}.md を読め。他の行動はすべてその後に行え。役割ファイルの許可リストにない行動はすべて禁止である。"
    echo "claude --model ${model} --dangerously-skip-permissions --append-system-prompt \"${prompt}\""
}

# --- .ol-soldiers ディレクトリの初期化 ---
init_project_dir() {
    mkdir -p "${OLS_DIR}"/{queue/{tasks,reports,inbox},logs}

    touch "${OLS_DIR}/queue/commander_to_sergeant.yaml"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        touch "${OLS_DIR}/queue/tasks/soldier${i}.yaml"
        touch "${OLS_DIR}/queue/reports/soldier${i}_report.yaml"
        touch "${OLS_DIR}/queue/inbox/soldier${i}.yaml"
    done
    touch "${OLS_DIR}/queue/inbox/sergeant.yaml"
    touch "${OLS_DIR}/queue/inbox/commander.yaml"

    echo "# Dashboard - $(date '+%Y-%m-%d %H:%M')" > "${OLS_DIR}/dashboard.md"
    echo "状態: 待機中" >> "${OLS_DIR}/dashboard.md"

    local TEMPLATE_DIR
    TEMPLATE_DIR="$(dirname "$0")/../templates"
    if [ ! -f "${PROJECT_ROOT}/CLAUDE.md" ]; then
        cp "${TEMPLATE_DIR}/CLAUDE.md.template" "${PROJECT_ROOT}/CLAUDE.md"
        echo "[ols-start] CLAUDE.md を生成しました。プロジェクトに合わせて編集してください。"
    fi

    mkdir -p "${OLS_DIR}/roles"
    for role_template in "${TEMPLATE_DIR}"/roles/*.md.template; do
        [ -f "$role_template" ] || continue
        local role_name
        role_name="$(basename "$role_template" .md.template)"
        cp "$role_template" "${OLS_DIR}/roles/${role_name}.md"
    done

    if [ ! -f "${OLS_DIR}/config.yaml" ]; then
        cat > "${OLS_DIR}/config.yaml" <<EOF
project_name: "$(basename "$PROJECT_ROOT")"
project_root: "${PROJECT_ROOT}"
soldier_count: ${SOLDIER_COUNT}
models:
  commander: "opus"
  sergeant: "opus"
  soldiers_default: "opus"
language: "ja"
EOF
    fi
}

# --- ペインにCLIを起動 ---
launch_agent() {
    local agent_id="$1"
    local model="$2"
    local role="$3"

    local pane_id
    pane_id=$(find_pane_by_agent_id "$agent_id" "$PANE_MAP_FILE")

    local cmd
    cmd=$(build_claude_cmd "$model" "$agent_id" "$role")
    send_text_to_pane "$pane_id" "$cmd"
}

# --- WezTermペイン作成 ---
# Tab 1 (指揮タブ):
#   ┌──────────────┬──────────────┐
#   │  Commander   │  Sergeant    │
#   └──────────────┴──────────────┘
# Tab 2 (実行タブ):
#   ┌──────┬──────┐
#   │  S1  │  S2  │
#   ├──────┼──────┤
#   │  S3  │  S4  │
#   └──────┴──────┘
create_session() {
    # セッション重複チェック: pane_mapが存在し、ペインが生きていれば既存セッションあり
    if [ -f "$PANE_MAP_FILE" ]; then
        local first_pane
        first_pane=$(head -1 "$PANE_MAP_FILE" | cut -f2)
        if wezterm cli list --format json 2>/dev/null | grep -q "\"pane_id\":${first_pane}" 2>/dev/null; then
            echo "[ols-start] 既存セッションが見つかりました。停止してから再実行してください。"
            echo "  停止コマンド: ols-stop"
            exit 1
        fi
        rm -f "$PANE_MAP_FILE"
    fi

    # pane_mapファイルを初期化
    : > "$PANE_MAP_FILE"

    # === Tab 1: Commander | Sergeant (左右50%) ===
    local commander_pane
    commander_pane=$(wezterm cli spawn --cwd "$PROJECT_ROOT")
    save_pane_mapping "commander" "$commander_pane" "$PANE_MAP_FILE"

    local sergeant_pane
    sergeant_pane=$(wezterm cli split-pane --pane-id "$commander_pane" --right --percent 50 --cwd "$PROJECT_ROOT")
    save_pane_mapping "sergeant" "$sergeant_pane" "$PANE_MAP_FILE"

    # === Tab 2: Soldiers (四方分割) ===
    local first_soldier
    first_soldier=$(wezterm cli spawn --cwd "$PROJECT_ROOT")

    # 上下に分割
    local bottom_row
    bottom_row=$(wezterm cli split-pane --pane-id "$first_soldier" --bottom --percent 50 --cwd "$PROJECT_ROOT")
    local top_row="$first_soldier"

    # 上段・下段のSoldier数を計算（奇数の場合は上段が1つ多い）
    local top_count=$(( (SOLDIER_COUNT + 1) / 2 ))
    local bottom_count=$(( SOLDIER_COUNT / 2 ))

    local soldier_panes=()

    # --- 上段を横に均等分割 (S1, S2, ...) ---
    local current_pane="$top_row"
    for i in $(seq 1 $((top_count - 1))); do
        local remaining=$((top_count - i))
        local pct=$(( 100 * remaining / (remaining + 1) ))
        local new_pane
        new_pane=$(wezterm cli split-pane --pane-id "$current_pane" --right --percent "$pct" --cwd "$PROJECT_ROOT")
        soldier_panes+=("$current_pane")
        current_pane="$new_pane"
    done
    soldier_panes+=("$current_pane")

    # --- 下段を横に均等分割 (S3, S4, ...) ---
    current_pane="$bottom_row"
    for i in $(seq 1 $((bottom_count - 1))); do
        local remaining=$((bottom_count - i))
        local pct=$(( 100 * remaining / (remaining + 1) ))
        local new_pane
        new_pane=$(wezterm cli split-pane --pane-id "$current_pane" --right --percent "$pct" --cwd "$PROJECT_ROOT")
        soldier_panes+=("$current_pane")
        current_pane="$new_pane"
    done
    soldier_panes+=("$current_pane")

    for i in $(seq 1 "$SOLDIER_COUNT"); do
        save_pane_mapping "soldier${i}" "${soldier_panes[$((i-1))]}" "$PANE_MAP_FILE"
    done

    # Commander ペインにフォーカス
    wezterm cli activate-pane --pane-id "$commander_pane"

    # --- Claude CLI 起動 ---

    launch_agent "commander" "opus"   "commander"
    launch_agent "sergeant"  "opus"   "sergeant"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        launch_agent "soldier${i}" "opus" "soldier"
    done
}

# --- inbox_watcher 起動 ---
start_watchers() {
    local SCRIPTS_DIR
    SCRIPTS_DIR="$(dirname "$0")/../scripts"
    local PIDS_FILE="${OLS_DIR}/logs/watcher.pids"
    : > "$PIDS_FILE"

    local agents=("commander" "sergeant")
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        agents+=("soldier${i}")
    done

    for agent_id in "${agents[@]}"; do
        local pane_id
        pane_id=$(find_pane_by_agent_id "$agent_id" "$PANE_MAP_FILE")
        bash "$SCRIPTS_DIR/inbox_watcher.sh" "$agent_id" "$pane_id" "$PROJECT_ROOT" &
        echo $! >> "$PIDS_FILE"
    done

    echo "[ols-start] inbox_watcher を起動しました（${#agents[@]} プロセス）"
}

# --- ターミナルUI表示 ---
open_terminal_ui() {
    local commander_pane soldier1_pane
    commander_pane=$(find_pane_by_agent_id "commander" "$PANE_MAP_FILE")
    soldier1_pane=$(find_pane_by_agent_id "soldier1" "$PANE_MAP_FILE")

    wezterm cli set-tab-title --pane-id "$commander_pane" "OLS: Command"
    wezterm cli set-tab-title --pane-id "$soldier1_pane" "OLS: Soldiers"
    wezterm cli activate-pane --pane-id "$commander_pane"

    echo "[ols-start] 起動完了"
    echo "  ソルジャー数: ${SOLDIER_COUNT}"
}

# --- メイン ---
init_project_dir
create_session
start_watchers
open_terminal_ui
