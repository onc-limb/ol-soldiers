#!/bin/bash
# commands/ols-start
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

PROJECT_ROOT="$(pwd)"
OLS_DIR="${PROJECT_ROOT}/.ol-soldiers"
SOLDIER_COUNT="${1:-4}"
SESSION="ols"

# --- ロール注入用のシステムプロンプトを生成 ---
build_claude_cmd() {
    local model="$1"
    local agent_id="$2"
    local role="$3"
    local prompt="あなたは ol-soldiers マルチエージェントシステムの「${role}」である（agent_id: ${agent_id}）。起動したらまず .ol-soldiers/roles/${role}.md を読め。他の行動はすべてその後に行え。役割ファイルの許可リストにない行動はすべて禁止である。"
    echo "claude --model ${model} --dangerously-skip-permissions --append-system-prompt \"${prompt}\""
}

# --- .ol-soldiers ディレクトリの初期化 ---
init_project_dir() {
    mkdir -p "${OLS_DIR}"/{queue/{tasks,reports,inbox},logs}

    touch "${OLS_DIR}/queue/commander_to_sergeant.yaml"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        touch "${OLS_DIR}/queue/tasks/soldier${i}.yaml"
        touch "${OLS_DIR}/queue/reports/soldier${i}_report.yaml"
        touch "${OLS_DIR}/queue/inbox/soldier${i}.yaml"
    done
    touch "${OLS_DIR}/queue/inbox/sergeant.yaml"
    touch "${OLS_DIR}/queue/inbox/commander.yaml"

    echo "# Dashboard - $(date '+%Y-%m-%d %H:%M')" > "${OLS_DIR}/dashboard.md"
    echo "状態: 待機中" >> "${OLS_DIR}/dashboard.md"

    local TEMPLATE_DIR
    TEMPLATE_DIR="$(dirname "$0")/../templates"
    if [ ! -f "${PROJECT_ROOT}/CLAUDE.md" ]; then
        cp "${TEMPLATE_DIR}/CLAUDE.md.template" "${PROJECT_ROOT}/CLAUDE.md"
        echo "[ols-start] CLAUDE.md を生成しました。プロジェクトに合わせて編集してください。"
    fi

    mkdir -p "${OLS_DIR}/roles"
    for role_template in "${TEMPLATE_DIR}"/roles/*.md.template; do
        [ -f "$role_template" ] || continue
        local role_name
        role_name="$(basename "$role_template" .md.template)"
        cp "$role_template" "${OLS_DIR}/roles/${role_name}.md"
    done

    if [ ! -f "${OLS_DIR}/config.yaml" ]; then
        cat > "${OLS_DIR}/config.yaml" <<EOF
project_name: "$(basename "$PROJECT_ROOT")"
project_root: "${PROJECT_ROOT}"
soldier_count: ${SOLDIER_COUNT}
models:
  commander: "opus"
  sergeant: "opus"
  soldiers_default: "sonnet"
language: "ja"
EOF
    fi
}

# --- ペインにagent_idを設定してCLIを起動 ---
launch_agent() {
    local agent_id="$1"
    local model="$2"
    local role="$3"

    local pane_index
    pane_index=$(find_pane_by_agent_id "$agent_id" "$SESSION")
    local target="${SESSION}:0.${pane_index}"

    tmux set-option -p -t "$target" @model_name "$model"
    local cmd
    cmd=$(build_claude_cmd "$model" "$agent_id" "$role")
    tmux send-keys -t "$target" "$cmd" Enter
}

# --- tmuxセッション作成 ---
# レイアウト:
#   ┌──────────┬──────────┬──────────┐
#   │          │ Soldier1 │ Soldier2 │
#   │Commander ├──────────┼──────────┤
#   ├──────────┤ Soldier3 │ Soldier4 │
#   │Sergeant  │          │          │
#   └──────────┴──────────┴──────────┘
create_session() {
    if tmux has-session -t "$SESSION" 2>/dev/null; then
        echo "[ols-start] 既存セッションが見つかりました。停止してから再実行してください。"
        echo "  停止コマンド: ols-stop"
        exit 1
    fi

    # --- ペイン作成 ---

    # Pane 0: Commander（全体の起点）
    tmux new-session -d -s "$SESSION" -c "$PROJECT_ROOT" -x 200 -y 50
    tmux set-option -p -t "${SESSION}:0.0" @agent_id "commander"

    # 左右に分割: 左40%（指揮系統）/ 右60%（実働部隊）
    # → Pane 1（右側全体、後でSoldier用に分割）
    tmux split-window -t "${SESSION}:0.0" -h -p 60 -c "$PROJECT_ROOT"

    # 左ペインを上下に分割: Commander(上) / Sergeant(下)
    # → Pane 2（Sergeant）
    tmux split-window -t "${SESSION}:0.0" -v -p 50 -c "$PROJECT_ROOT"
    tmux set-option -p -t "${SESSION}:0.2" @agent_id "sergeant"

    # 右ペイン(1)を上下に分割: 上段 / 下段
    # → Pane 3（右下）
    tmux split-window -t "${SESSION}:0.1" -v -p 50 -c "$PROJECT_ROOT"

    # 右上(1)を左右に分割: Soldier1 / Soldier2
    # → Pane 4（Soldier2）
    tmux split-window -t "${SESSION}:0.1" -h -p 50 -c "$PROJECT_ROOT"
    tmux set-option -p -t "${SESSION}:0.1" @agent_id "soldier1"
    tmux set-option -p -t "${SESSION}:0.4" @agent_id "soldier2"

    # 右下(3)を左右に分割: Soldier3 / Soldier4
    # → Pane 5（Soldier4）
    tmux split-window -t "${SESSION}:0.3" -h -p 50 -c "$PROJECT_ROOT"
    tmux set-option -p -t "${SESSION}:0.3" @agent_id "soldier3"
    tmux set-option -p -t "${SESSION}:0.5" @agent_id "soldier4"

    # Commander ペインにフォーカス
    tmux select-pane -t "${SESSION}:0.0"

    # --- Claude CLI 起動 ---

    launch_agent "commander" "opus"   "commander"
    launch_agent "sergeant"  "opus"   "sergeant"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        launch_agent "soldier${i}" "sonnet" "soldier"
    done
}

# --- inbox_watcher 起動 ---
start_watchers() {
    local SCRIPTS_DIR
    SCRIPTS_DIR="$(dirname "$0")/../scripts"
    local PIDS_FILE="${OLS_DIR}/logs/watcher.pids"
    : > "$PIDS_FILE"

    local agents=("commander" "sergeant")
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        agents+=("soldier${i}")
    done

    for agent_id in "${agents[@]}"; do
        local pane_index
        pane_index=$(find_pane_by_agent_id "$agent_id" "$SESSION")
        bash "$SCRIPTS_DIR/inbox_watcher.sh" "$agent_id" "${SESSION}:0.${pane_index}" "$PROJECT_ROOT" &
        echo $! >> "$PIDS_FILE"
    done

    echo "[ols-start] inbox_watcher を起動しました（${#agents[@]} プロセス）"
}

# --- ターミナルUI表示 ---
open_terminal_ui() {
    if [ -z "${WEZTERM_PANE:-}" ]; then
        echo "[ols-start] 起動完了"
        echo "  接続: tmux attach -t ${SESSION}"
        echo "  ソルジャー数: ${SOLDIER_COUNT}"
        return
    fi

    local pane_id
    pane_id=$(wezterm cli spawn --cwd "$PROJECT_ROOT" -- tmux attach -t "$SESSION")
    wezterm cli set-tab-title --pane-id "$pane_id" "OL-Soldiers"

    echo "[ols-start] 起動完了（wezterm タブを開きました）"
    echo "  ソルジャー数: ${SOLDIER_COUNT}"
}

# --- メイン ---
init_project_dir
create_session
start_watchers
open_terminal_ui
