#!/bin/bash
# commands/ols-start
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

PROJECT_ROOT="$(pwd)"
OLS_DIR="${PROJECT_ROOT}/.ol-soldiers"
PANE_MAP_FILE="$(get_pane_map_file "$PROJECT_ROOT")"

# --- 引数パース ---
SOLDIER_COUNT=4
INSPECTOR_COUNT=3
NO_EVALUATE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-evaluate)
            NO_EVALUATE=true
            shift
            ;;
        [0-9]*)
            SOLDIER_COUNT="$1"
            shift
            ;;
        *)
            echo "[ols-start] 不明なオプション: $1" >&2
            exit 1
            ;;
    esac
done

# --- ロール注入用のシステムプロンプトを生成 ---
build_claude_cmd() {
    local model="$1"
    local agent_id="$2"
    local role="$3"
    local persona=""
    case "$role" in
        commander) persona="" ;;
        sergeant)  persona="" ;;
        soldier)   persona="" ;;
        inspector) persona="" ;;
    esac
    local prompt="あなたは ol-soldiers の ${role}（agent_id: ${agent_id}）。起動時に .ol-soldiers/roles/${role}.md を読め。許可リスト外の行動は禁止。"
    echo "claude --model ${model} --dangerously-skip-permissions --append-system-prompt \"${prompt}\""
}

# --- .ol-soldiers ディレクトリの初期化 ---
init_project_dir() {
    # .gitignore に .ol-soldiers/ を追加
    local gitignore_file="${PROJECT_ROOT}/.gitignore"
    if [ -f "$gitignore_file" ]; then
        if ! grep -q "^\.ol-soldiers/$" "$gitignore_file"; then
            echo ".ol-soldiers/" >> "$gitignore_file"
        fi
    else
        echo ".ol-soldiers/" > "$gitignore_file"
    fi

    mkdir -p "${OLS_DIR}"/{queue/{tasks,reports,inbox},logs}

    touch "${OLS_DIR}/queue/commander_to_sergeant.yaml"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        touch "${OLS_DIR}/queue/tasks/soldier${i}.yaml"
        touch "${OLS_DIR}/queue/reports/soldier${i}_report.yaml"
        touch "${OLS_DIR}/queue/inbox/soldier${i}.yaml"
    done
    if [ "$NO_EVALUATE" = false ]; then
        for i in $(seq 1 "$INSPECTOR_COUNT"); do
            touch "${OLS_DIR}/queue/tasks/inspector${i}.yaml"
            touch "${OLS_DIR}/queue/reports/inspector${i}_report.yaml"
            touch "${OLS_DIR}/queue/inbox/inspector${i}.yaml"
        done
    fi
    touch "${OLS_DIR}/queue/inbox/sergeant.yaml"
    touch "${OLS_DIR}/queue/inbox/commander.yaml"

    echo "# Dashboard - $(date '+%Y-%m-%d %H:%M')" > "${OLS_DIR}/dashboard.md"
    echo "状態: 待機中" >> "${OLS_DIR}/dashboard.md"

    local TEMPLATE_DIR
    TEMPLATE_DIR="$(dirname "$0")/../templates"
    if [ ! -f "${PROJECT_ROOT}/CLAUDE.md" ]; then
        cp "${TEMPLATE_DIR}/CLAUDE.md.template" "${PROJECT_ROOT}/CLAUDE.md"
        echo "[ols-start] CLAUDE.md を生成しました。プロジェクトに合わせて編集してください。"
    fi

    mkdir -p "${OLS_DIR}/roles"
    for role_template in "${TEMPLATE_DIR}"/roles/*.md.template; do
        [ -f "$role_template" ] || continue
        local role_name
        role_name="$(basename "$role_template" .md.template)"
        cp "$role_template" "${OLS_DIR}/roles/${role_name}.md"
    done

    mkdir -p "${OLS_DIR}/specialties"
    for specialty_file in "${TEMPLATE_DIR}"/specialties/*.md; do
        [ -f "$specialty_file" ] || continue
        cp "$specialty_file" "${OLS_DIR}/specialties/"
    done

    local evaluate_flag="true"
    if [ "$NO_EVALUATE" = true ]; then
        evaluate_flag="false"
    fi
    cat > "${OLS_DIR}/config.yaml" <<EOF
project_name: "$(basename "$PROJECT_ROOT")"
project_root: "${PROJECT_ROOT}"
soldier_count: ${SOLDIER_COUNT}
inspector_count: ${INSPECTOR_COUNT}
evaluate: ${evaluate_flag}
models:
  commander: "opus"
  sergeant: "opus"
  soldiers_default: "opus"
  inspectors_default: "opus"
language: "ja"
EOF
}

# --- ペインにCLIを起動 ---
launch_agent() {
    local agent_id="$1"
    local model="$2"
    local role="$3"

    local pane_id
    pane_id=$(find_pane_by_agent_id "$agent_id" "$PANE_MAP_FILE")

    local cmd
    cmd=$(build_claude_cmd "$model" "$agent_id" "$role")
    send_text_to_pane "$pane_id" "$cmd"
}

# --- ヘルパー: N人分のエージェントペインを1タブに配置（2xN/2 グリッド） ---
# 引数: start_num end_num [prefix]
# prefix: "soldier"（デフォルト）または "inspector"
create_agent_tab() {
    local start_num="$1"
    local end_num="$2"
    local prefix="${3:-soldier}"
    local count=$((end_num - start_num + 1))

    local first_pane
    first_pane=$(wezterm cli spawn --cwd "$PROJECT_ROOT")
    sleep 0.5

    # 上下2段に分割
    local bottom_row
    bottom_row=$(wezterm cli split-pane --pane-id "$first_pane" --bottom --percent 50 --cwd "$PROJECT_ROOT") || {
        echo "[ols-start] ERROR: ペイン分割に失敗しました（上下）。WezTermウィンドウを大きくしてから再実行してください。" >&2
        exit 1
    }
    sleep 0.3
    local top_row="$first_pane"

    local top_count=$(( (count + 1) / 2 ))
    local bottom_count=$(( count / 2 ))
    # bottom_count=1のとき、上段のみ右分割するとWezTermが意図しない4ペインを生成する。
    # 上下を入れ替えて回避（上段=1ペイン全幅、下段=複数ペイン）。
    if [ "$bottom_count" -eq 1 ] && [ "$top_count" -gt 1 ]; then
        local _swap=$top_count
        top_count=1
        bottom_count=$_swap
    fi
    local tab_panes=()

    # 上段を横に均等分割
    # NOTE: macOS の BSD seq は "seq 1 0" が "1\n0" を返すため bash 算術ループを使う
    local current_pane="$top_row"
    local i
    for ((i=1; i<top_count; i++)); do
        local remaining=$((top_count - i))
        local pct=$(( 100 * remaining / (remaining + 1) ))
        local new_pane
        new_pane=$(wezterm cli split-pane --pane-id "$current_pane" --right --percent "$pct" --cwd "$PROJECT_ROOT") || {
            echo "[ols-start] ERROR: ペイン分割に失敗しました（上段）。WezTermウィンドウを大きくしてから再実行してください。" >&2
            exit 1
        }
        tab_panes+=("$current_pane")
        current_pane="$new_pane"
    done
    tab_panes+=("$current_pane")

    # 下段を横に均等分割
    current_pane="$bottom_row"
    for ((i=1; i<bottom_count; i++)); do
        local remaining=$((bottom_count - i))
        local pct=$(( 100 * remaining / (remaining + 1) ))
        local new_pane
        new_pane=$(wezterm cli split-pane --pane-id "$current_pane" --right --percent "$pct" --cwd "$PROJECT_ROOT") || {
            echo "[ols-start] ERROR: ペイン分割に失敗しました（下段）。WezTermウィンドウを大きくしてから再実行してください。" >&2
            exit 1
        }
        tab_panes+=("$current_pane")
        current_pane="$new_pane"
    done
    tab_panes+=("$current_pane")

    # pane_map に登録
    local idx=0
    for num in $(seq "$start_num" "$end_num"); do
        save_pane_mapping "${prefix}${num}" "${tab_panes[$idx]}" "$PANE_MAP_FILE"
        idx=$((idx + 1))
    done

    echo "$first_pane"
}

# --- WezTermペイン作成 ---
# Tab 1 (指揮タブ):
#   ┌──────────────┬──────────────┐
#   │  Commander   │  Sergeant    │
#   └──────────────┴──────────────┘
# Tab 2 (Soldiers):
#   ┌──────┬──────┬──────┐
#   │  S1  │  S2  │  S3  │
#   ├──────┼──────┴──────┤
#   │  S4  │     S5      │
#   └──────┴─────────────┘
# Tab 3 (Inspectors, --no-evaluate でない場合):
#   ┌──────────────┐
#   │     I1       │
#   ├──────┬───────┤
#   │  I2  │  I3   │
#   └──────┴───────┘
create_session() {
    # セッション重複チェック: pane_mapが存在し、ペインが生きていれば既存セッションあり
    if [ -f "$PANE_MAP_FILE" ]; then
        local first_pane
        first_pane=$(head -1 "$PANE_MAP_FILE" | cut -f2)
        if wezterm cli list --format json 2>/dev/null | grep -q "\"pane_id\":${first_pane}" 2>/dev/null; then
            echo "[ols-start] 既存セッションが見つかりました。停止してから再実行してください。"
            echo "  停止コマンド: ols-stop"
            exit 1
        fi
        rm -f "$PANE_MAP_FILE"
    fi

    # pane_mapファイルを初期化
    : > "$PANE_MAP_FILE"

    # === Tab 1: Commander | Sergeant (左右50%) ===
    local commander_pane
    commander_pane=$(wezterm cli spawn --cwd "$PROJECT_ROOT")
    sleep 0.5
    save_pane_mapping "commander" "$commander_pane" "$PANE_MAP_FILE"

    local sergeant_pane
    sergeant_pane=$(wezterm cli split-pane --pane-id "$commander_pane" --right --percent 50 --cwd "$PROJECT_ROOT") || {
        echo "[ols-start] ERROR: ペイン分割に失敗しました（commander/sergeant）。WezTermウィンドウを大きくしてから再実行してください。" >&2
        exit 1
    }
    save_pane_mapping "sergeant" "$sergeant_pane" "$PANE_MAP_FILE"

    # === Tab 2: Soldiers ===
    local tab2_first
    tab2_first=$(create_agent_tab 1 "$SOLDIER_COUNT" "soldier")

    # === Tab 3: Inspectors (--no-evaluate でない場合のみ) ===
    if [ "$NO_EVALUATE" = false ]; then
        create_agent_tab 1 "$INSPECTOR_COUNT" "inspector" > /dev/null
    fi

    # Commander ペインにフォーカス
    wezterm cli activate-pane --pane-id "$commander_pane"

    local commander_model sergeant_model soldiers_model inspectors_model
    commander_model=$(grep "commander:" "${OLS_DIR}/config.yaml" | tail -1 | awk '{print $2}' | tr -d '"')
    sergeant_model=$(grep "sergeant:" "${OLS_DIR}/config.yaml" | tail -1 | awk '{print $2}' | tr -d '"')
    soldiers_model=$(grep "soldiers_default:" "${OLS_DIR}/config.yaml" | awk '{print $2}' | tr -d '"')
    inspectors_model=$(grep "inspectors_default:" "${OLS_DIR}/config.yaml" | awk '{print $2}' | tr -d '"')
    commander_model="${commander_model:-opus}"
    sergeant_model="${sergeant_model:-opus}"
    soldiers_model="${soldiers_model:-opus}"
    inspectors_model="${inspectors_model:-opus}"

    # --- ペインタイトル設定 ---
    set_pane_title "$commander_pane" "commander ($commander_model)"
    set_pane_title "$sergeant_pane" "sergeant ($sergeant_model)"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        local pane_id
        pane_id=$(find_pane_by_agent_id "soldier${i}" "$PANE_MAP_FILE")
        set_pane_title "$pane_id" "soldier${i} ($soldiers_model)"
    done
    if [ "$NO_EVALUATE" = false ]; then
        for i in $(seq 1 "$INSPECTOR_COUNT"); do
            local pane_id
            pane_id=$(find_pane_by_agent_id "inspector${i}" "$PANE_MAP_FILE")
            set_pane_title "$pane_id" "inspector${i} ($inspectors_model)"
        done
    fi

    # --- Claude CLI 起動 ---
    launch_agent "commander" "$commander_model" "commander"
    launch_agent "sergeant"  "$sergeant_model"  "sergeant"
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        launch_agent "soldier${i}" "$soldiers_model" "soldier"
    done
    if [ "$NO_EVALUATE" = false ]; then
        for i in $(seq 1 "$INSPECTOR_COUNT"); do
            launch_agent "inspector${i}" "$inspectors_model" "inspector"
        done
    fi
}

# --- inbox_watcher 起動 ---
start_watchers() {
    local SCRIPTS_DIR
    SCRIPTS_DIR="$(dirname "$0")/../scripts"
    local PIDS_FILE="${OLS_DIR}/logs/watcher.pids"
    : > "$PIDS_FILE"

    local agents=("commander" "sergeant")
    for i in $(seq 1 "$SOLDIER_COUNT"); do
        agents+=("soldier${i}")
    done
    if [ "$NO_EVALUATE" = false ]; then
        for i in $(seq 1 "$INSPECTOR_COUNT"); do
            agents+=("inspector${i}")
        done
    fi

    for agent_id in "${agents[@]}"; do
        local pane_id
        pane_id=$(find_pane_by_agent_id "$agent_id" "$PANE_MAP_FILE")
        bash "$SCRIPTS_DIR/inbox_watcher.sh" "$agent_id" "$pane_id" "$PROJECT_ROOT" &
        echo $! >> "$PIDS_FILE"
    done

    echo "[ols-start] inbox_watcher を起動しました（${#agents[@]} プロセス）"
}

# --- ターミナルUI表示 ---
open_terminal_ui() {
    local commander_pane soldier1_pane
    commander_pane=$(find_pane_by_agent_id "commander" "$PANE_MAP_FILE")
    soldier1_pane=$(find_pane_by_agent_id "soldier1" "$PANE_MAP_FILE")

    wezterm cli set-tab-title --pane-id "$commander_pane" "OLS: Command"
    wezterm cli set-tab-title --pane-id "$soldier1_pane" "OLS: Soldiers 1-${SOLDIER_COUNT}"
    if [ "$NO_EVALUATE" = false ]; then
        local inspector1_pane
        inspector1_pane=$(find_pane_by_agent_id "inspector1" "$PANE_MAP_FILE")
        wezterm cli set-tab-title --pane-id "$inspector1_pane" "OLS: Inspectors 1-${INSPECTOR_COUNT}"
    fi
    wezterm cli activate-pane --pane-id "$commander_pane"

    echo "[ols-start] 起動完了"
    echo "  ソルジャー数: ${SOLDIER_COUNT}"
    if [ "$NO_EVALUATE" = false ]; then
        echo "  インスペクター数: ${INSPECTOR_COUNT}"
        echo "  評価モード: ON"
    else
        echo "  評価モード: OFF (--no-evaluate)"
    fi
}

# --- メイン ---
init_project_dir
create_session
start_watchers
open_terminal_ui
